{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "keepandroidopen-dot-org",
  "compatibility_date": "2026-05-24",
  "compatibility_flags": [
    "nodejs_compat" // Thêm flag này để Cloudflare hỗ trợ module "node:fs"
  ],
  "pages_build_output_dir": "dist",
  "observability": {
    "enabled": true
  }
}
